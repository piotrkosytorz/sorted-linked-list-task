{
    "name": "piotrkosytorz/sorted-linked-list",
    "description": "A sorted linked list for int or string values",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Piotr\\SortedLinkedList\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Piotr\\SortedLinkedList\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "check": ["@analyse", "@test"]
    }
}
